model Vendor {
  id     String @id @default(uuid())
  userId String @unique @map("user_id")

  companyName        String  @map("company_name")
  registrationNumber String  @unique @map("registration_number")
  taxNumber          String? @map("tax_number")
  yearsInBusiness    Int?    @map("years_in_business")

  addressStreet  String? @map("address_street")
  addressCity    String? @map("address_city")
  addressState   String? @map("address_state")
  addressZipCode String? @map("address_zip_code")

  productsServices String[]     @map("products_services")
  websiteUrl       String?      @map("website_url")
  contactEmail     String?      @map("contact_email")
  contactPhone     String?      @map("contact_phone")
  vendorStatus     VendorStatus @default(pending) @map("vendor_status")
  rejectionReason  String?      @map("rejection_reason")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  user              User       @relation(fields: [userId], references: [id])
  suppliedMaterials Material[]

  @@index([companyName])
  @@index([addressCity])
  @@index([addressState])
  @@index([vendorStatus])
  @@map("vendors")
}
