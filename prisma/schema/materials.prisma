model Material {
  id         String @id @default(uuid())
  projectId  String @map("project_id")

  materialName String @map("material_name")
  materialCode String @map("material_code")
  category     String

  description    String?
  specifications String?

  currentStock Float  @default(0) @map("current_stock")
  unit         String
  unitPrice    Float? @map("unit_price")

  reorderLevel        Float?  @map("reorder_level")
  storageLocation     String? @map("storage_location")
  preferredSupplierId String? @map("preferred_supplier_id")
  status              String  @default("in_stock") // in_stock, low_stock, out_of_stock

  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project           Project @relation(fields: [projectId], references: [id])
  preferredSupplier Vendor? @relation(fields: [preferredSupplierId], references: [id])
  creator           User    @relation(fields: [createdBy], references: [id])

  transactions MaterialTransaction[]

  @@unique([projectId, materialCode])
  @@index([materialName])
  @@index([category])
  @@index([status])
  @@map("materials")
}

model MaterialTransaction {
  id         String @id @default(uuid())
  materialId String @map("material_id")

  type     String // IN, OUT, ADJUSTMENT
  quantity Float
  date     DateTime @default(now())

  referenceId String? // Invoice ID, Task ID, etc. @map("reference_id")
  performedBy String? // User ID @map("performed_by")
  notes       String?

  material Material @relation(fields: [materialId], references: [id])

  @@index([materialId])
  @@index([date])
  @@map("material_transactions")
}

model MaterialRequest {
  id            String @id @default(uuid())
  requestNumber String @unique @map("request_number")
  projectId     String @map("project_id")
  requestedBy   String @map("requested_by")

  items Json // Array of { material_id, material_name, quantity, ... }

  priority         String   @default("medium") // low, medium, high, urgent
  purpose          String?
  deliveryLocation String?  @map("delivery_location")
  requiredDate     DateTime @map("required_date")

  status String @default("pending") // pending, approved, rejected, partially_fulfilled, fulfilled, cancelled

  approvedBy       String?   @map("approved_by")
  approvedAt       DateTime? @map("approved_at")
  approvalComments String?   @map("approval_comments")

  rejectionReason String? @map("rejection_reason")

  convertedToPo Boolean @default(false) @map("converted_to_po")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project   Project @relation(fields: [projectId], references: [id])
  requester User    @relation("RequestedMaterials", fields: [requestedBy], references: [id])
  approver  User?   @relation("ApprovedMaterials", fields: [approvedBy], references: [id])

  @@index([projectId])
  @@index([requestedBy])
  @@index([status])
  @@map("material_requests")
}
