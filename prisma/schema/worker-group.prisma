enum TradeType {
    MASON
    CARPENTER
    PLUMBER
    ELECTRICIAN
    PAINTER
    HELPER
    TILER
    WELDER
    DRIVER
    LABOUR
    OTHER
}

model WorkerGroup {
    id          String    @id @default(uuid())
    name        String
    description String?
    trade       TradeType @default(LABOUR)
    createdById String    @map("created_by_id")
    isActive    Boolean   @default(true) @map("is_active")
    createdAt   DateTime  @default(now()) @map("created_at")
    updatedAt   DateTime  @updatedAt @map("updated_at")
    isDeleted   Boolean   @default(false) @map("is_deleted")
    deletedAt   DateTime? @map("deleted_at")

    user    User                @relation(fields: [createdById], references: [id])
    workers WorkerGroupMember[]

    @@index([createdById])
    @@index([isActive])
    @@map("worker_groups")
}

model WorkerGroupMember {
    id            String    @id @default(uuid())
    workerGroupId String    @map("worker_group_id")
    workerId      String    @map("worker_id")
    joinedAt      DateTime  @default(now()) @map("joined_at")
    isActive      Boolean   @default(true) @map("is_active")
    createdAt     DateTime  @default(now()) @map("created_at")
    updatedAt     DateTime  @updatedAt @map("updated_at")
    isDeleted     Boolean   @default(false) @map("is_deleted")
    deletedAt     DateTime? @map("deleted_at")

    workerGroup WorkerGroup  @relation(fields: [workerGroupId], references: [id])
    worker      Professional @relation(fields: [workerId], references: [id])

    @@unique([workerGroupId, workerId])
    @@index([workerGroupId])
    @@index([workerId])
    @@index([isActive])
    @@map("worker_group_members")
}
