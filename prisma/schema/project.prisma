enum ProjectStatus {
  active
  paused
  completed
  on_hold
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

enum ProjectMemberRole {
  manager
  supervisor
  engineer
}

enum Status {
  not_started
  in_progress
  completed
  delayed
  on_hold
}

enum TaskPriority {
  low
  medium
  high
  critical
}

enum AttendanceMethod {
  manual
  qr_code
  biometric
}

model Project {
  id          String        @id @default(uuid())
  name        String
  managerIds  String[]      @map("manager_ids")
  description String?
  icon        String        @default("folder")
  status      ProjectStatus @default(active)
  progress    Int           @default(0)
  budget      Float?
  spent       Float?

  startDate DateTime? @map("start_date")
  dueDate   DateTime? @map("due_date")

  latitude  Float?
  longitude Float?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  members          ProjectMember[]
  phases           ProjectPhase[]
  attendance       Attendance[]
  materials        Material[]
  materialRequests MaterialRequest[]
  workerGroups     WorkerGroup[]

  @@index([name])
  @@index([status])
  @@map("projects")
}

model ProjectMember {
  id        String            @id @default(uuid())
  projectId String            @map("project_id")
  userId    String            @map("user_id")
  role      ProjectMemberRole
  isCreator Boolean           @default(false) @map("is_creator")
  joinedAt  DateTime          @default(now()) @map("joined_at")

  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  project Project @relation(fields: [projectId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@map("project_members")
}

model ProjectPhase {
  id               String    @id @default(uuid())
  projectId        String    @map("project_id")
  name             String
  description      String?
  progress         Int       @default(0)
  plannedStartDate DateTime? @map("planned_start_date")
  plannedEndDate   DateTime? @map("planned_end_date")
  actualStartDate  DateTime? @map("actual_start_date")
  actualEndDate    DateTime? @map("actual_end_date")
  status           Status    @default(not_started)
  sequence         Int
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  project     Project         @relation(fields: [projectId], references: [id])
  approvals   PhaseApproval[]
  tasks       Task[]
  attendances Attendance[]

  @@index([projectId])
  @@map("project_phases")
}

model PhaseApproval {
  id             String         @id @default(uuid())
  phaseId        String         @map("phase_id")
  approvedBy     String?        @map("approved_by")
  requestedBy    String         @map("requested_by")
  approvalStatus ApprovalStatus @default(pending) @map("approval_status")
  comments       String?
  media          Json // Array of MediaItem { type, url }
  approvedAt     DateTime?      @map("approved_at")
  requestedAt    DateTime       @default(now()) @map("requested_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  phase     ProjectPhase @relation(fields: [phaseId], references: [id])
  approver  User?        @relation("ApproverRelation", fields: [approvedBy], references: [id])
  requester User         @relation("RequesterRelation", fields: [requestedBy], references: [id])

  @@index([phaseId])
  @@index([approvedBy])
  @@index([requestedBy])
  @@map("phase_approvals")
}

model Attendance {
  id              String           @id @default(uuid())
  projectId       String           @map("project_id")
  phaseId         String?          @map("phase_id")
  userId          String           @map("user_id")
  date            DateTime
  checkIn         DateTime?        @map("check_in")
  checkOut        DateTime?        @map("check_out")
  status          String
  location        String?
  workHours       Float?           @map("work_hours")
  method          AttendanceMethod @default(manual)
  supervisorNotes String?          @map("supervisor_notes")
  isVerified      Boolean          @default(false) @map("is_verified")
  verifiedBy      String?          @map("verified_by")
  verifiedAt      DateTime?        @map("verified_at")

  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  phase    ProjectPhase? @relation(fields: [phaseId], references: [id])
  project  Project       @relation(fields: [projectId], references: [id])
  user     User          @relation(fields: [userId], references: [id])
  verifier User?         @relation("AttendanceVerifier", fields: [verifiedBy], references: [id])

  @@map("attendance")
}

model Task {
  id               String       @id @default(uuid())
  phaseId          String       @map("phase_id")
  assignedTo       String?      @map("assigned_to")
  name             String
  description      String?
  plannedStartDate DateTime?    @map("planned_start_date")
  plannedEndDate   DateTime?    @map("planned_end_date")
  actualStartDate  DateTime?    @map("actual_start_date")
  actualEndDate    DateTime?    @map("actual_end_date")
  estimatedHours   Float?       @map("estimated_hours")
  actualHours      Float?       @map("actual_hours")
  status           Status       @default(not_started)
  priority         TaskPriority @default(medium)
  progress         Int          @default(0)
  color            String? // Hex color code
  notes            String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  phase    ProjectPhase @relation(fields: [phaseId], references: [id])
  assignee User?        @relation("TaskAssignee", fields: [assignedTo], references: [id])

  successors   TaskDependency[] @relation("TaskSuccessor")
  predecessors TaskDependency[] @relation("TaskPredecessor")

  @@index([phaseId])
  @@index([assignedTo])
  @@map("tasks")
}

model TaskDependency {
  id                String @id @default(uuid())
  phaseId           String @map("phase_id")
  successorTaskId   String @map("successor_task_id")
  predecessorTaskId String @map("predecessor_task_id")

  type    String  @default("FS") // 'FS', 'SS', 'FF', 'SF'
  lagTime Int     @default(0) @map("lag_time") // In days
  notes   String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  successor   Task @relation("TaskSuccessor", fields: [successorTaskId], references: [id])
  predecessor Task @relation("TaskPredecessor", fields: [predecessorTaskId], references: [id])

  @@index([successorTaskId])
  @@index([predecessorTaskId])
  @@index([phaseId])
  @@map("task_dependencies")
}
