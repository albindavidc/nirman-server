model Professional {
  id                String @id @default(uuid())
  userId            String @unique @map("user_id")
  professionalTitle String @map("professional_title")

  experienceYears Int      @map("experience_years")
  skills          String[]

  addressStreet  String @map("address_street")
  addressCity    String @map("address_city")
  addressState   String @map("address_state")
  addressZipCode String @map("address_zip_code")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])
  workerGroups WorkerGroupMember[]

  @@index([professionalTitle])
  @@index([experienceYears])
  @@index([skills])
  @@index([addressCity])
  @@index([addressState])
  @@map("professionals")
}
